# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local data — never commit the database or submitted orders (contain client PII)
/data/acc-jobs.db
/data/acc-jobs.db-shm
/data/acc-jobs.db-wal
/data/orders/
/data/archives/
/data/jobs/

# Real customer drawings — never commit
/EXAMPLE DRAWINGS/

# Cab Door reference PDFs (kept for ingest, not to be public)
/Patternguide_2024_web.pdf
/2026_productshowcase.pdf

# Local secrets file
secrets.txt
